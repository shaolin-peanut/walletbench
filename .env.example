# WalletBench environment configuration
# Deployment target: Railway (recommended) — see README Deployment section.
# Vercel is NOT recommended because better-sqlite3 requires native addons and a writable filesystem.

# Database
# Use an absolute path inside the Railway container mount. Default: /app/data/walletbench.db
DB_PATH=/app/data/walletbench.db

# Stripe test credentials (test mode only)
STRIPE_TEST_SECRET_KEY=sk_test_***
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_***
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_***

# Runtime
NODE_ENV=production
PORT=3000
